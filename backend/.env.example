# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# For local development (direct connection):
# MONGO_URI=mongodb://localhost:27017/radif
#
# For Docker deployment (use the service name, not localhost):
# MONGO_URI=mongodb://mongo:27017/radif
#
# For MongoDB Atlas (cloud):
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a strong random string (minimum 32 characters) in production
JWT_SECRET=replace_with_a_strong_random_secret

# ─── Cookie Security ──────────────────────────────────────────────────────────
# Set to 'true' ONLY when running behind HTTPS (SSL certificate required)
# Set to 'false' for plain HTTP (local dev, Docker without SSL)
COOKIE_SECURE=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the frontend — used for CORS allowlist
# For Docker with Nginx (same-origin): http://YOUR_SERVER_IP
# For local dev: http://localhost:5173
CLIENT_URL=http://localhost:5173

# ─── Environment ──────────────────────────────────────────────────────────────
# Use 'production' for live deployments, 'development' for local/Docker HTTP
NODE_ENV=development
